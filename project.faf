  deployment: npm (faf-wasm-sdk)
  key_files:
    - src/lib.rs
    - src/mk4.rs
    - src/fafb.rs
  commands:
    test: cargo test
    build: wasm-pack build --target web --release
    publish: "wasm-pack publish (via pkg/)"
    doc: cargo doc --open
stack:
  backend: Rust 2021 Edition (compiled to WASM)
  build_tool: wasm-pack + Cargo
